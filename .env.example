# These are first-boot defaults only. Once the app has started once, use
# the Settings page in the web UI to change any of this -- env vars are
# only read to seed the database the very first time it's created.

# Immich connection (e.g. IMMICH_API_BASE=https://immich.example.com/api)
# Leave blank to configure from the Settings page instead -- a non-empty
# placeholder here is treated as "configured" and the app will actually try
# to connect to it.
IMMICH_API_BASE=
IMMICH_API_KEY=

# Default filters
ASSET_TYPES=IMAGE,VIDEO
INCLUDE_ARCHIVED=false
INCLUDE_DELETED=false

# Image encoding distance (JXL)
# 0 = mathematically lossless, 1 = visually lossless, higher = more compression/smaller files
# Note: JPEGs use cjxl lossless repack (distance is ignored). This applies to PNG, WebP, HEIC, AVIF, etc.
IMAGE_DISTANCE=1.0
IMAGE_DISTANCE_RETRY=2.0

# Video encoding (SVT-AV1)
VIDEO_CRF=36
VIDEO_PRESET=4
VIDEO_MAX_DIMENSION=0
VIDEO_AUDIO_BITRATE=64k
VIDEO_CRF_RETRY=40

# Retry behavior: retry with more compression if output is larger than input
ENABLE_RETRY=true
ACCEPT_RETRY_OUTPUT=false

# Safety: keep output even if larger than input
ALLOW_LARGER=false

# Parallel workers per run
CONCURRENCY=2

# Logging
LOG_LEVEL=INFO
